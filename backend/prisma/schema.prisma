// Coffee Bun — Prisma Schema
// PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  EMPLOYEE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

enum SalaryType {
  HOURLY
  MONTHLY
  HYBRID
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  AUTO_CLOSED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  LOCKED
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  employeeCode  String?  @unique
  passwordHash  String
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  failedLogins  Int      @default(0)
  lockedUntil   DateTime?
  twoFactorSecret String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  employee      Employee?
  auditLogs     AuditLog[] @relation("AuditActor")

  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  name        RoleName @unique
  description String?
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String @id @default(uuid())
  key         String @unique // e.g. employees.create
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role       Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@id([roleId, permissionId])
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  employees Employee[]
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  latitude  Float?
  longitude Float?
  geofenceRadiusM Int @default(150)
  timezone  String   @default("Asia/Kolkata")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  networkConfigs NetworkConfiguration[]
  attendance Attendance[]
  shifts     Shift[]

  @@index([code])
}

model Shift {
  id               String @id @default(uuid())
  name             String
  startTime        String // "09:00"
  endTime          String // "18:00"
  graceMinutes     Int    @default(15)
  breakMinutes     Int    @default(60)
  overtimeAfterMin Int    @default(480)
  branchId         String?
  branch           Branch? @relation(fields: [branchId], references: [id])
  employees Employee[]
  createdAt DateTime @default(now())
}

model Employee {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode     String   @unique
  fullName         String
  phone            String?
  address          String?
  dob              DateTime?
  emergencyContact String?
  joiningDate      DateTime @default(now())
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id])
  position         String?
  employmentStatus EmploymentStatus @default(ACTIVE)
  terminatedAt     DateTime?
  salaryType       SalaryType @default(MONTHLY)
  hourlyRate       Decimal  @db.Decimal(12,2) @default(0)
  monthlySalary    Decimal  @db.Decimal(12,2) @default(0)
  overtimeRate     Decimal  @db.Decimal(12,2) @default(0)
  branchId         String?
  branch           Branch? @relation(fields: [branchId], references: [id])
  shiftId          String?
  shift            Shift? @relation(fields: [shiftId], references: [id])
  profilePhotoId   String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?

  attendance Attendance[]
  payroll    Payroll[]
  faceData   FaceData?
  locations  EmployeeLocation[]
  leaveRequests LeaveRequest[]

  @@index([employeeCode])
  @@index([branchId])
  @@index([departmentId])
}

model FaceData {
  id                 String @id @default(uuid())
  employeeId         String @unique
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  imageFileId        String?
  embeddingRef       String? // opaque ref, e.g. S3 key, never raw vector in public
  embeddingProvider  String @default("local")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Attendance {
  id                      String @id @default(uuid())
  employeeId              String
  employee                Employee @relation(fields: [employeeId], references: [id])
  date                    DateTime @db.Date
  punchInAt               DateTime?
  punchOutAt              DateTime?
  punchInLat              Float?
  punchInLng              Float?
  punchOutLat             Float?
  punchOutLng             Float?
  punchInIp               String?
  punchOutIp              String?
  punchInDevice           Json?
  punchOutDevice          Json?
  selfieVerified          Boolean @default(false)
  selfieConfidence        Float?
  selfieFileId            String?
  networkVerified         Boolean @default(false)
  geofenceVerified        Boolean @default(false)
  status                  AttendanceStatus @default(PRESENT)
  workedMinutes           Int @default(0)
  overtimeMinutes         Int @default(0)
  lateMinutes             Int @default(0)
  earlyLeaveMinutes       Int @default(0)
  dailyEarnings           Decimal @db.Decimal(12,2) @default(0)
  autoClosed              Boolean @default(false)
  branchId                String?
  branch                  Branch? @relation(fields: [branchId], references: [id])
  deletedAt               DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  corrections AttendanceCorrection[]
  locations   EmployeeLocation[]

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([date])
  @@index([branchId])
}

model AttendanceCorrection {
  id            String @id @default(uuid())
  attendanceId  String
  attendance    Attendance @relation(fields: [attendanceId], references: [id])
  requestedById String
  reason        String
  requestedPunchIn  DateTime?
  requestedPunchOut DateTime?
  status        LeaveStatus @default(PENDING)
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime @default(now())
}

model Payroll {
  id              String @id @default(uuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id])
  periodStart     DateTime @db.Date
  periodEnd       DateTime @db.Date
  totalWorkedMin  Int @default(0)
  overtimeMin     Int @default(0)
  grossAmount     Decimal @db.Decimal(12,2)
  bonus           Decimal @db.Decimal(12,2) @default(0)
  deductions      Decimal @db.Decimal(12,2) @default(0)
  advances        Decimal @db.Decimal(12,2) @default(0)
  netAmount       Decimal @db.Decimal(12,2)
  pendingAmount   Decimal @db.Decimal(12,2) @default(0)
  status          PayrollStatus @default(DRAFT)
  approvedById    String?
  approvedAt      DateTime?
  locked          Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([employeeId, periodStart])
}

model LeaveRequest {
  id          String @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  leaveType   String
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  reason      String?
  status      LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
}

model Holiday {
  id         String @id @default(uuid())
  name       String
  date       DateTime @db.Date
  branchId   String?
  department String?
  paid       Boolean @default(true)
  createdAt  DateTime @default(now())
  @@unique([date, name])
}

model NetworkConfiguration {
  id                String @id @default(uuid())
  branchId          String
  branch            Branch @relation(fields: [branchId], references: [id])
  name              String
  publicIp          String?
  cidr              String?
  gatewayToken      String?
  isActive          Boolean @default(true)
  createdAt         DateTime @default(now())

  @@index([branchId])
}

model EmployeeLocation {
  id           String @id @default(uuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  attendanceId String?
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])
  latitude     Float
  longitude    Float
  accuracy     Float?
  recordedAt   DateTime @default(now())
  source       String // punch_in / punch_out / auto

  @@index([employeeId, recordedAt])
}

model Notification {
  id         String @id @default(uuid())
  userId     String
  title      String
  body       String
  read       Boolean @default(false)
  meta       Json?
  createdAt  DateTime @default(now())
  @@index([userId, read])
}

model AuditLog {
  id          String @id @default(uuid())
  actorId     String?
  actor       User? @relation("AuditActor", fields: [actorId], references: [id])
  action      String
  entity      String
  entityId    String?
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model ActivityLog {
  id        String @id @default(uuid())
  userId    String?
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model Setting {
  key       String @id
  value     Json
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id          String @id @default(uuid())
  userId      String
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())
  @@index([userId])
}

model PasswordResetToken {
  id         String @id @default(uuid())
  userId     String
  tokenHash  String @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
}

model DeviceSession {
  id            String @id @default(uuid())
  userId        String
  fingerprint   String
  userAgent     String?
  ip            String?
  lastSeenAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  @@index([userId])
}

model UploadedFile {
  id          String @id @default(uuid())
  filename    String
  mimeType    String
  size        Int
  storageKey  String
  storage     String @default("local") // local | s3
  isPrivate   Boolean @default(true)
  uploadedBy  String?
  createdAt   DateTime @default(now())
}
